<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    
    <!-- Package Metadata -->
    <PackageId>Inertia.React</PackageId>
    <Version>0.1.1</Version>
    <Authors>Inertia.NET Contributors</Authors>
    <Description>React adapter for Inertia.js on ASP.NET Core</Description>
    <PackageTags>inertia;react;spa;aspnetcore;ssr</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/ps-carvalho/Inertia.React</RepositoryUrl>
    <PackageProjectUrl>https://github.com/ps-carvalho/Inertia.React</PackageProjectUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="tests\**" />
    <EmbeddedResource Remove="tests\**" />
    <None Remove="tests\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Inertia.Core" Version="0.1.1" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="contentFiles\**\*" Pack="true" PackagePath="contentFiles\" />
  </ItemGroup>

</Project>
